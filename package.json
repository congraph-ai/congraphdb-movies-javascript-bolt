{
  "name": "movies-congraphdb-javascript",
  "version": "0.1.6",
  "description": "Demo application using CongraphDB embedded graph database",
  "repository": "",
  "license": "Apache-2.0",
  "private": true,
  "dependencies": {
    "congraphdb": "^0.1.7",
    "express": "^4.22.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "css-loader": "^6.10.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.0",
    "rimraf": "^3.0.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "webpack",
    "seed": "node scripts/seed-database.js",
    "start": "node server.js",
    "start:cypher": "cross-env CONGRAPHDB_API_MODE=cypher node server.js",
    "start:js": "cross-env CONGRAPHDB_API_MODE=javascript node server.js",
    "dev": "npm run build && node server.js",
    "dev:cypher": "npm run build && cross-env CONGRAPHDB_API_MODE=cypher node server.js",
    "dev:js": "npm run build && cross-env CONGRAPHDB_API_MODE=javascript node server.js",
    "dev:seed": "npm run seed && npm run dev"
  }
}
